generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  name          String               @db.VarChar(255)
  email         String               @unique @db.VarChar(255)
  password      String               @db.VarChar(255)
  createdAt     DateTime             @default(now())
  id            Int                  @id @default(autoincrement())
  role          USER_ROLE            @default(STUDENT)
  assignments   Assignment[]         @relation("AssignedBy")
  chatSessions  ChatSession[]
  conversations Conversation[]       @relation("CreatedConversations")
  courses       Course[]
  exercises     Exercise[]
  gradedSubs    ExerciseSubmission[] @relation("GradedBy")
  messages      Message[]
  notifications Notification[]
  refreshTokens RefreshToken[]
  student       Student?
  transactions  Transaction[]
  tutor         Tutor?
}

model RefreshToken {
  id        String   @id @db.Char(36)
  token     String   @unique @db.VarChar(512)
  userId    Int
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Student {
  id            String               @id @db.Char(36)
  gradeLevel    String?              @db.VarChar(50)
  schoolName    String?              @db.VarChar(255)
  learningGoals String?
  userId        Int                  @unique
  enrollments   ClassEnrollment[]
  submissions   ExerciseSubmission[]
  attendances   SessionAttendance[]
  user          User                 @relation(fields: [userId], references: [id])
  progress      StudentProgress[]
}

model Tutor {
  id                      String             @id @db.Char(36)
  bio                     String?
  teachingExperienceYears Int?
  hourlyRate              Decimal?           @db.Decimal(10, 2)
  rating                  Decimal?           @db.Decimal(3, 2)
  isVerified              Boolean?
  status                  String?            @db.VarChar(50)
  userId                  Int                @unique
  autoAssignConfigs       AutoAssignConfig[]
  classes                 Class[]
  sessions                Session[]
  user                    User               @relation(fields: [userId], references: [id])
  subjects                TutorSubject[]
}

model Subject {
  id                String             @id @db.Char(36)
  name              String             @db.VarChar(255)
  parentSubjectId   String?            @db.Char(36)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  grade             Int?
  autoAssignConfigs AutoAssignConfig[]
  courses           Course[]
  exercises         Exercise[]
  studentProgresses StudentProgress[]
  parent            Subject?           @relation("SubjectHierarchy", fields: [parentSubjectId], references: [id])
  children          Subject[]          @relation("SubjectHierarchy")
  topics            Topic[]
  tutorSubjects     TutorSubject[]
}

model Topic {
  id                String             @id @db.Char(36)
  subjectId         String             @db.Char(36)
  name              String             @db.VarChar(255)
  orderIndex        Int?
  parentTopicId     String?            @db.Char(36)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  autoAssignConfigs AutoAssignConfig[]
  exercises         Exercise[]
  studentProgresses StudentProgress[]
  parent            Topic?             @relation("TopicHierarchy", fields: [parentTopicId], references: [id])
  children          Topic[]            @relation("TopicHierarchy")
  subject           Subject            @relation(fields: [subjectId], references: [id])
}

model TutorSubject {
  id               String  @id @db.Char(36)
  tutorId          String  @db.Char(36)
  subjectId        String  @db.Char(36)
  proficiencyLevel String? @db.VarChar(50)
  subject          Subject @relation(fields: [subjectId], references: [id])
  tutor            Tutor   @relation(fields: [tutorId], references: [id])
}

model Exercise {
  id                 String               @id @db.Char(36)
  title              String?              @db.VarChar(255)
  subjectId          String?              @db.Char(36)
  topicId            String?              @db.Char(36)
  exerciseType       String?              @db.VarChar(50)
  contentType        String?              @db.VarChar(50)
  difficultyLevel    String?              @db.VarChar(50)
  totalPoints        Decimal?             @db.Decimal(6, 2)
  timeLimitMinutes   Int?
  isAiGenerated      Boolean              @default(false)
  aiGenerationConfig Json?
  status             String?              @default("draft") @db.VarChar(50)
  createdBy          Int?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  grade              Int?
  assignments        Assignment[]
  creator            User?                @relation(fields: [createdBy], references: [id])
  subject            Subject?             @relation(fields: [subjectId], references: [id])
  topic              Topic?               @relation(fields: [topicId], references: [id])
  attachments        ExerciseAttachment[]
  questions          ExerciseQuestion[]
}

model ExerciseQuestion {
  id               String               @id @db.Char(36)
  exerciseId       String               @db.Char(36)
  questionText     String?
  questionType     String?              @db.VarChar(50)
  orderIndex       Int?
  points           Decimal?             @db.Decimal(6, 2)
  content          Json?
  explanation      String?
  hints            Json?
  autoGrade        Boolean              @default(false)
  aiGradingEnabled Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  attachments      ExerciseAttachment[]
  exercise         Exercise             @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  answers          SubmissionAnswer[]
}

model ExerciseAttachment {
  id         String            @id @db.Char(36)
  exerciseId String            @db.Char(36)
  questionId String?           @db.Char(36)
  fileName   String            @db.VarChar(255)
  fileUrl    String
  publicId   String?           @db.VarChar(255)
  fileType   String            @db.VarChar(100)
  fileSize   Int?
  createdAt  DateTime          @default(now())
  exercise   Exercise          @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  question   ExerciseQuestion? @relation(fields: [questionId], references: [id])
}

model Assignment {
  id             String               @id @db.Char(36)
  exerciseId     String               @db.Char(36)
  assignedToType String?              @db.VarChar(50)
  assignedToId   String?              @db.Char(36)
  dueDate        DateTime?
  maxAttempts    Int?
  status         String?              @db.VarChar(50)
  assignedBy     Int?
  assigner       User?                @relation("AssignedBy", fields: [assignedBy], references: [id])
  exercise       Exercise             @relation(fields: [exerciseId], references: [id])
  submissions    ExerciseSubmission[]
}

model ExerciseSubmission {
  id            String             @id @db.Char(36)
  assignmentId  String             @db.Char(36)
  studentId     String             @db.Char(36)
  attemptNumber Int?
  submittedAt   DateTime?
  totalScore    Decimal?           @db.Decimal(6, 2)
  percentage    Decimal?           @db.Decimal(5, 2)
  status        String?            @db.VarChar(50)
  isLate        Boolean?
  gradedBy      Int?
  assignment    Assignment         @relation(fields: [assignmentId], references: [id])
  grader        User?              @relation("GradedBy", fields: [gradedBy], references: [id])
  student       Student            @relation(fields: [studentId], references: [id])
  answers       SubmissionAnswer[]
}

model SubmissionAnswer {
  id           String             @id @db.Char(36)
  submissionId String             @db.Char(36)
  questionId   String             @db.Char(36)
  answerData   Json?
  isCorrect    Boolean?
  pointsEarned Decimal?           @db.Decimal(6, 2)
  feedback     String?
  question     ExerciseQuestion   @relation(fields: [questionId], references: [id])
  submission   ExerciseSubmission @relation(fields: [submissionId], references: [id])
}

model Course {
  id        String         @id @db.Char(36)
  name      String?        @db.VarChar(255)
  subjectId String?        @db.Char(36)
  level     String?        @db.VarChar(50)
  price     Decimal?       @db.Decimal(10, 2)
  status    String?        @db.VarChar(50)
  createdBy Int?
  classes   Class[]
  creator   User?          @relation(fields: [createdBy], references: [id])
  subject   Subject?       @relation(fields: [subjectId], references: [id])
  modules   CourseModule[]
}

model CourseModule {
  id         String         @id @db.Char(36)
  courseId   String         @db.Char(36)
  title      String?        @db.VarChar(255)
  orderIndex Int?
  lessons    CourseLesson[]
  course     Course         @relation(fields: [courseId], references: [id])
}

model CourseLesson {
  id              String       @id @db.Char(36)
  moduleId        String       @db.Char(36)
  title           String?      @db.VarChar(255)
  contentType     String?      @db.VarChar(50)
  durationMinutes Int?
  orderIndex      Int?
  module          CourseModule @relation(fields: [moduleId], references: [id])
}

model Class {
  id                String             @id @db.Char(36)
  courseId          String?            @db.Char(36)
  name              String?            @db.VarChar(255)
  tutorId           String?            @db.Char(36)
  startDate         DateTime?
  endDate           DateTime?
  maxStudents       Int?
  status            String?            @db.VarChar(50)
  grade             Int?
  autoAssignConfigs AutoAssignConfig[]
  course            Course?            @relation(fields: [courseId], references: [id])
  tutor             Tutor?             @relation(fields: [tutorId], references: [id])
  enrollments       ClassEnrollment[]
  sessions          Session[]
}

model ClassEnrollment {
  id                 String   @id @db.Char(36)
  classId            String   @db.Char(36)
  studentId          String   @db.Char(36)
  status             String?  @db.VarChar(50)
  progressPercentage Decimal? @db.Decimal(5, 2)
  class              Class    @relation(fields: [classId], references: [id])
  student            Student  @relation(fields: [studentId], references: [id])
}

model Session {
  id             String              @id @db.Char(36)
  classId        String?
  tutorId        String
  title          String?             @db.VarChar(255)
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  meetingLink    String?
  status         String?             @db.VarChar(50)
  class          Class?              @relation(fields: [classId], references: [id])
  tutor          Tutor               @relation(fields: [tutorId], references: [id])
  attendances    SessionAttendance[]
}

model SessionAttendance {
  id        String    @id @db.Char(36)
  sessionId String    @db.Char(36)
  studentId String    @db.Char(36)
  status    String?   @db.VarChar(50)
  joinedAt  DateTime?
  session   Session   @relation(fields: [sessionId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id])
}

model StudentProgress {
  id                 String   @id @db.Char(36)
  studentId          String   @db.Char(36)
  subjectId          String?
  topicId            String?
  exercisesCompleted Int?
  averageScore       Decimal? @db.Decimal(5, 2)
  masteryLevel       String?  @db.VarChar(50)
  student            Student  @relation(fields: [studentId], references: [id])
  subject            Subject? @relation(fields: [subjectId], references: [id])
  topic              Topic?   @relation(fields: [topicId], references: [id])
}

model Notification {
  id               String   @id @db.Char(36)
  title            String?  @db.VarChar(255)
  message          String?
  notificationType String?  @db.VarChar(50)
  isRead           Boolean  @default(false)
  metadata         Json?
  userId           Int
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model Conversation {
  id               String    @id @db.Char(36)
  conversationType String?   @db.VarChar(50)
  createdBy        Int?
  creator          User?     @relation("CreatedConversations", fields: [createdBy], references: [id])
  messages         Message[]
}

model Message {
  id             String       @id @db.Char(36)
  conversationId String       @db.Char(36)
  messageText    String?
  attachments    Json?
  senderId       Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
}

model Transaction {
  id              String   @id @db.Char(36)
  amount          Decimal? @db.Decimal(10, 2)
  transactionType String?  @db.VarChar(50)
  paymentMethod   String?  @db.VarChar(50)
  status          String?  @db.VarChar(50)
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
}

model ChatSession {
  id        String        @id @db.Char(36)
  userId    Int
  title     String        @db.VarChar(255)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id            String      @id @db.Char(36)
  chatSessionId String      @db.Char(36)
  role          String      @db.VarChar(50)
  content       String
  attachments   Json?
  createdAt     DateTime    @default(now())
  session       ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
}

model AutoAssignConfig {
  id              String   @id @db.Char(36)
  tutorId         String   @db.Char(36)
  classId         String?  @db.Char(36)
  subjectId       String   @db.Char(36)
  topicId         String?  @db.Char(36)
  difficultyLevel String?  @db.VarChar(50)
  exercisesPerDay Int      @default(1)
  isActive        Boolean  @default(true)
  daysOfWeek      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  class           Class?   @relation(fields: [classId], references: [id])
  subject         Subject  @relation(fields: [subjectId], references: [id])
  topic           Topic?   @relation(fields: [topicId], references: [id])
  tutor           Tutor    @relation(fields: [tutorId], references: [id])
}

enum USER_ROLE {
  ADMIN
  TEACHER
  STUDENT
}
