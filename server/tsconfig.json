{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "outDir": "./build",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
    },
    "resolveJsonModule": true,
    "allowJs": true,
  },
  "include": ["src", "prisma.config.ts"],
  "exclude": ["*.test.ts"],
  "ts-node": {
    "files": true
  }
}
